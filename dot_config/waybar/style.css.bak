@import "frappe.css";

* {
    border: none;
    border-radius: 0px;
    font-family: "CommitMono Nerd Font", JetBrainsMono Nerd Font, Font Awesome, sans-serif;
    font-size: 13px;
    min-height: 0;
}

window#waybar {
    background: transparent;
    border: none;
    color: @text;
}

tooltip {
    background: @mantle;
    border: 2px solid @surface0;
    border-radius: 0px;
}

tooltip label {
    color: @text;
}

#workspaces {
    background: @mantle;
    margin: 5px;
    padding: 0 4px;
}

#workspaces button {
    padding: 0 8px;
    margin: 4px 2px;
    border-radius: 0px;
    color: @lavender;
    background: transparent;
    transition: all 0.2s ease;
}

#workspaces button:hover {
    background: @surface0;
    color: @text;
}

#workspaces button.focused {
    background: @blue;
    color: @base;
}

#workspaces button.urgent {
    background: @red;
    color: @base;
}

#window,
#clock,
#battery,
#battery.bat2,
#cpu,
#memory,
#temperature,
#backlight,
#network,
#pulseaudio,
#tray,
#mode,
#idle_inhibitor,
#mpd,
#language,
#keyboard-state,
#power-profiles-daemon,
#custom-media,
#custom-power,
#scratchpad {
    background: @mantle;
    color: @text;
    margin: 5px 3px;
    padding: 0 12px;
}

#window {
    color: @lavender;
}

#clock {
    color: @blue;
}

#battery {
    color: @green;
}

#battery.warning {
    color: @yellow;
}

#battery.critical {
    color: @red;
}

#cpu {
    color: @peach;
}

#memory {
    color: @mauve;
}

#temperature {
    color: @maroon;
}

#temperature.critical {
    color: @red;
}

#backlight {
    color: @yellow;
}

#network {
    color: @teal;
}

#network.disconnected {
    color: @red;
}

#pulseaudio {
    color: @flamingo;
}

#pulseaudio.muted {
    color: @overlay1;
}

#idle_inhibitor {
    color: @green;
}

#idle_inhibitor.activated {
    color: @red;
}

#mpd {
    color: @pink;
}

#language {
    color: @sky;
}

#keyboard-state {
    color: @sapphire;
}

#power-profiles-daemon {
    color: @lavender;
}

#custom-media {
    color: @mauve;
}

#custom-power {
    color: @red;
    margin-right: 8px;
}

#tray {
    padding-right: 8px;
}
