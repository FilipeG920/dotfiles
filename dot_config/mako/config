# Position & History
anchor=top-right
layer=overlay
max-visible=5
max-history=100

# Size
# width=400
# height=150

# Sort & Group order
sort=-time
group-by=app-name

# Icons & Markup
icons=1
markup=1

default-timeout=5000
# Colors

background-color=#303446
text-color=#c6d0f5
border-color=#8caaee
progress-color=over #414559

# Format and font
border-size=2
border-radius=10
padding=10
font=monoid 11

# Interactions
on-button-left=invoke-default-action
on-button-right=dismiss
on-button-middle=dismiss-group

[urgency=high]
default-timeout=0
ignore-timeout=1
border-color=#ef9f76
